# Single-card recommended fastpath template for Qwen3.5-9B-class 910A deployment.
# Adjust paths for your own CANN / OPP / Python environment.

# Pick one card for this worker.
ASCEND_RT_VISIBLE_DEVICES=0

# Custom OPP path. Point this to the installed customize directory, not its parent.
ASCEND_CUSTOM_OPP_PATH=/path/to/custom_opp/customize

# Recurrent decode extension import path, if it is not installed into site-packages.
PYTHONPATH=/path/to/recurrent_decode_extension/python:${PYTHONPATH}

# Keep skinny decode matmul eligible for ACLNN.
QWEN35_RECURRENT_DECODE_EAGER_ACLNN_SKINNY_MATMUL_POLICY=allow

# Shape-aware fused_step route.
QWEN35_RECURRENT_DECODE_EAGER_USE_FUSED_STEP_AUTO_FP16_QKV_ONLY=1
QWEN35_RECURRENT_DECODE_EAGER_FUSED_STEP_AUTO_FP16_QKV_ONLY_BUCKETS=128x128,128x96,96x128,96x96,96x160,160x96

# Keep the fast registered state-update route for batch_step.
QWEN35_RECURRENT_DECODE_EAGER_USE_REGISTERED_STATE_UPDATE_OP=1
QWEN35_RECURRENT_DECODE_EAGER_USE_FUSED_STEP_REGISTERED_STATE_UPDATE_OP=1

# Enable AscendC host-stub split route only for small fused_step paths.
# The implementation should disable this route from batch_step transition contexts.
QWEN35_RECURRENT_DECODE_EAGER_USE_ASCENDC_STATE_UPDATE_HOST_STUB=1
QWEN35_ASCENDC_STATE_UPDATE_PRIVATEUSE1_SPLIT_DEVICE_OP=1

# Do not force the high-precision KV custom-op split unless accuracy requires it.
QWEN35_ASCENDC_STATE_UPDATE_SPLIT_USE_KV_CUSTOM_OP=0

