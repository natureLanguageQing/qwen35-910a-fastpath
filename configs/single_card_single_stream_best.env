# Single-card, single-stream best-known profile (as of 2026-04-11).
# Keep this profile isolated to one card and benchmark with max_tokens=256 first.

ASCEND_RT_VISIBLE_DEVICES=0
TP_SIZE=1
MAX_MODEL_LEN=4096
GPU_MEM_UTIL=0.92
VLLM_QWEN35_POST_START_WARMUP=0

# Decode fastpath core switches.
VLLM_ENABLE_FLA_PACKED_RECURRENT_DECODE=1
VLLM_QWEN35_USE_ASCEND_CUSTOM_RECURRENT_DECODE_PACKED=1
VLLM_QWEN35_USE_ASCEND_CUSTOM_RECURRENT_DECODE_PACKED_BATCH_STEP=1
QWEN35_RECURRENT_DECODE_EAGER_USE_FUSED_STEP_FP16_COMPUTE=1
QWEN35_RECURRENT_DECODE_EAGER_USE_FUSED_STEP_OUT_ADDCMUL=1
QWEN35_RECURRENT_DECODE_EAGER_USE_BATCH_STEP_SINGLE_TOKEN_FASTPATH=0

# Keep prefill conservative, optimize decode.
VLLM_QWEN35_FORCE_ASCEND_PREFILL_REFERENCE=1
VLLM_QWEN35_FORCE_ASCEND_DECODE_REFERENCE=0

# Causal-conv update path.
VLLM_QWEN35_USE_ASCEND_CUSTOM_CAUSAL_CONV1D_UPDATE=1
QWEN35_ASCEND_CAUSAL_CONV1D_USE_REGISTERED_OP=1
QWEN35_ASCEND_CAUSAL_CONV1D_USE_DIRECT_DOT=1

# solve_tril path stayed neutral/negative in this pass.
VLLM_QWEN35_USE_ASCEND_CUSTOM_SOLVE_TRIL=0
VLLM_QWEN35_USE_ASCEND_CUSTOM_SOLVE_TRIL_BLOCK64=1
